{
  "$schema": "./open_damos.schema.json",
  "ecu": "edc16c34",
  "name": "open_damos — EDC16C34 Bosch PSA",
  "version": "1.1.0",
  "license": "CC0-1.0",
  "homepage": "https://github.com/Poisson48/open_car_reprog/wiki/Open-DAMOS",
  "description": "Damos libre et gratuit pour Bosch EDC16C34 PSA (DV6TED4, 1.6 HDi 75/90/110 cv : Berlingo, Partner, 206, 207, 307, 308, 407, C3, C4, Fiesta TDCi, Mazda 2/3 MZ-CD). Chaque entrée inclut une empreinte d'axes permettant la relocalisation automatique sur n'importe quel firmware de la famille, sans besoin du damos Bosch propriétaire. Exportable en A2L ASAP2 standard (utilisable dans WinOLS, TunerPro, EcuFlash, open-car-reprog).",
  "baseline": {
    "source": "ressources/edc16c34/ori.BIN",
    "damos": "ressources/edc16c34/damos.a2l",
    "note": "Adresses et empreintes prélevées sur ori.BIN (match 100 % damos.a2l). Pour les autres firmwares (ex. SW 1037383736 Berlingo II 1.6 HDi 75), la relocalisation par empreinte retrouve les mêmes maps à des offsets différents."
  },
  "recordLayouts": {
    "Kf_Xs16_Ys16_Ws16": {
      "type": "MAP",
      "headerBytes": 4,
      "headerType": "UWORD_BE",
      "axisDataType": "SWORD_BE",
      "dataType": "SWORD_BE"
    },
    "Kl_Xs16_Ws16": {
      "type": "CURVE",
      "headerBytes": 2,
      "headerType": "UWORD_BE",
      "axisDataType": "SWORD_BE",
      "dataType": "SWORD_BE"
    },
